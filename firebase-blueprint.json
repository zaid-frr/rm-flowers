{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A flower product in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "description": { "type": "string", "description": "Product description" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs" },
        "dimensions": { "type": "string", "description": "Product dimensions" },
        "stylingTips": { "type": "string", "description": "Styling tips" },
        "specs": {
          "type": "object",
          "properties": {
            "material": { "type": "string" },
            "uvResistance": { "type": "string" },
            "cleaning": { "type": "string" }
          }
        },
        "category": { "type": "string", "description": "Product category" },
        "stock": { "type": "number", "description": "Available stock" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "description", "images"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "buyerName": { "type": "string" },
        "buyerEmail": { "type": "string" },
        "buyerPhone": { "type": "string" },
        "buyerAddress": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "image": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string", "description": "Optional user ID if logged in" }
      },
      "required": ["buyerName", "buyerEmail", "buyerPhone", "buyerAddress", "items", "total", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products."
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    }
  }
}
